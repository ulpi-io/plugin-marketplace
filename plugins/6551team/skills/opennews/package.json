{
  "name": "opennews",
  "version": "0.1.0",
  "description": "72+ real-time crypto & financial news sources across 5 categories (News, Listing, OnChain, Meme, Market) with AI ratings, trading signals, and bilingual summaries via the OpenNews 6551 API",
  "author": "0xfaskety",
  "license": "MIT",
  "homepage": "https://github.com/0xfaskety/opennews-mcp",
  "openclaw": {
    "skills": {
      "dependencies": {
        "tools": ["exec", "read"],
        "binaries": ["curl", "jq"],
        "envVars": ["OPENNEWS_TOKEN"]
      }
    }
  },
  "keywords": [
    "crypto",
    "news",
    "bitcoin",
    "trading",
    "ai-ratings",
    "signals",
    "blockchain",
    "defi",
    "bloomberg",
    "reuters",
    "onchain",
    "whale-tracking",
    "market-signals",
    "exchange-listings",
    "meme-coins",
    "real-time"
  ]
}
