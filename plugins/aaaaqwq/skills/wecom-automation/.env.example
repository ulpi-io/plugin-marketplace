# Wechaty 配置
WECHATY_PUPPET=padlocal
WECHATY_TOKEN=your_padlocal_token_here
WECHATY_LOG_LEVEL=info

# 企业微信账号配置
WECOM_NAME="企业微信机器人"
ADMIN_WECHATY_NAME=

# 临时文件目录
TMP_DIR=/tmp/wecom_bot

# 数据库配置
KB_DB_URL=postgresql://postgres@localhost/wecom_kb

# 知识库搜索配置
KB_SIMILARITY_THRESHOLD=0.7
KB_TOP_K=3

# LLM 配置
LLM_PROVIDER=kimi
LLM_API_KEY=
LLM_API_BASE=https://api.moonshot.cn/v1
LLM_MODEL=moonshot-v1-8k
LLM_EMBEDDING_MODEL=embedding-v1

# 人工介入通知配置
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNEL=telegram:YOUR_TELEGRAM_ID
TELEGRAM_BOT_TOKEN=

# 文件处理配置
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=docx,pdf,txt,md,jpg,png,gif

# 图片 OCR 配置
OCR_ENABLED=true
OCR_PROVIDER=kimi

# 语音识别配置
VOICE_TRANSCRIPTION_ENABLED=true
WHISPER_API_KEY=
