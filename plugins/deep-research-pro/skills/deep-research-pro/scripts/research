#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["ddgs>=7.0"]
# ///

"""
Deep Research Pro — multi-source research tool.
Searches multiple queries, deduplicates, and outputs structured results.
"""

import sys
import json
import re
import urllib.request
import ssl
from datetime import datetime
from ddgs import DDGS


def search_web(query, max_results=8):
    with DDGS() as ddgs:
        return list(ddgs.text(query, max_results=max_results))


def search_news(query, max_results=5):
    with DDGS() as ddgs:
        return list(ddgs.news(query, max_results=max_results))


def fetch_page(url, max_chars=5000):
    """Fetch and extract text from a URL."""
    try:
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        req = urllib.request.Request(url, headers={
            "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
        })
        with urllib.request.urlopen(req, timeout=15, context=ctx) as resp:
            html = resp.read().decode("utf-8", errors="ignore")
        # Strip HTML tags
        text = re.sub(r'<script[^>]*>.*?</script>', ' ', html, flags=re.DOTALL)
        text = re.sub(r'<style[^>]*>.*?</style>', ' ', text, flags=re.DOTALL)
        text = re.sub(r'<[^>]+>', ' ', text)
        text = re.sub(r'\s+', ' ', text).strip()
        return text[:max_chars]
    except Exception as e:
        return f"[Error fetching: {e}]"


def deduplicate(results):
    """Deduplicate by URL."""
    seen = set()
    unique = []
    for r in results:
        url = r.get("href") or r.get("url", "")
        if url and url not in seen:
            seen.add(url)
            unique.append(r)
    return unique


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print("""Deep Research Pro — multi-source research tool

Usage:
  research "<query1>" "<query2>" ...     Search multiple queries
  research --plan "<topic>"              Generate sub-questions for a topic
  research --fetch "<url>"               Fetch and extract text from URL
  research --full "<query1>" ...         Search + fetch top results

Options:
  --news           Include news search
  --max N          Max results per query (default 8)
  --json           Output as JSON
  --fetch-top N    Fetch full text of top N results (default 0)
  --output FILE    Save results to file
""")
        return

    # Parse flags
    include_news = False
    as_json = False
    max_results = 8
    fetch_top = 0
    output_file = None
    plan_mode = False
    fetch_mode = False
    full_mode = False
    queries = []

    i = 0
    while i < len(args):
        if args[i] == "--news":
            include_news = True
        elif args[i] == "--json":
            as_json = True
        elif args[i] == "--max" and i + 1 < len(args):
            i += 1
            max_results = int(args[i])
        elif args[i] == "--fetch-top" and i + 1 < len(args):
            i += 1
            fetch_top = int(args[i])
        elif args[i] == "--output" and i + 1 < len(args):
            i += 1
            output_file = args[i]
        elif args[i] == "--plan":
            plan_mode = True
        elif args[i] == "--fetch":
            fetch_mode = True
        elif args[i] == "--full":
            full_mode = True
            fetch_top = 3
            include_news = True
        else:
            queries.append(args[i])
        i += 1

    if fetch_mode and queries:
        # Just fetch URLs
        for url in queries:
            print(f"\n{'='*60}")
            print(f"URL: {url}")
            print(f"{'='*60}")
            text = fetch_page(url, max_chars=8000)
            print(text)
        return

    if not queries:
        print("Error: no queries provided", file=sys.stderr)
        sys.exit(1)

    all_results = []
    news_results = []

    # Search each query
    for q in queries:
        print(f"🔍 Searching: {q}", file=sys.stderr)
        try:
            results = search_web(q, max_results=max_results)
            all_results.extend(results)
        except Exception as e:
            print(f"  ⚠️ Web search error: {e}", file=sys.stderr)

        if include_news:
            try:
                news = search_news(q, max_results=5)
                news_results.extend(news)
            except Exception as e:
                print(f"  ⚠️ News search error: {e}", file=sys.stderr)

    # Deduplicate
    all_results = deduplicate(all_results)
    news_results = deduplicate(news_results)

    # Fetch top results if requested
    fetched = []
    if fetch_top > 0:
        for r in all_results[:fetch_top]:
            url = r.get("href", "")
            if url:
                print(f"📄 Fetching: {url}", file=sys.stderr)
                text = fetch_page(url)
                fetched.append({
                    "url": url,
                    "title": r.get("title", ""),
                    "content": text
                })

    # Output
    output = {
        "timestamp": datetime.now().isoformat(),
        "queries": queries,
        "web_results": all_results,
        "news_results": news_results,
        "fetched_pages": fetched,
        "stats": {
            "total_web": len(all_results),
            "total_news": len(news_results),
            "pages_fetched": len(fetched)
        }
    }

    if as_json:
        result = json.dumps(output, indent=2)
    else:
        lines = []
        lines.append(f"\n📊 Research Results — {datetime.now().strftime('%Y-%m-%d %H:%M')}")
        lines.append(f"Queries: {', '.join(queries)}")
        lines.append(f"Found: {len(all_results)} web results, {len(news_results)} news results")
        lines.append("")

        if all_results:
            lines.append("=" * 60)
            lines.append("🌐 WEB RESULTS")
            lines.append("=" * 60)
            for i, r in enumerate(all_results, 1):
                title = r.get("title", "No title")
                url = r.get("href", "")
                body = r.get("body", "")[:200]
                lines.append(f"\n{i}. {title}")
                lines.append(f"   {url}")
                if body:
                    lines.append(f"   {body}")

        if news_results:
            lines.append("")
            lines.append("=" * 60)
            lines.append("📰 NEWS RESULTS")
            lines.append("=" * 60)
            for i, r in enumerate(news_results, 1):
                title = r.get("title", "No title")
                url = r.get("href") or r.get("url", "")
                source = r.get("source", "")
                date = r.get("date", "")
                lines.append(f"\n{i}. {title}")
                if source:
                    lines.append(f"   Source: {source} | {date}")
                lines.append(f"   {url}")

        if fetched:
            lines.append("")
            lines.append("=" * 60)
            lines.append("📄 FETCHED PAGES")
            lines.append("=" * 60)
            for f_item in fetched:
                lines.append(f"\n--- {f_item['title']} ---")
                lines.append(f"URL: {f_item['url']}")
                lines.append(f"{f_item['content'][:3000]}")

        result = "\n".join(lines)

    if output_file:
        with open(output_file, "w") as f:
            f.write(result)
        print(f"✅ Saved to {output_file}", file=sys.stderr)
    else:
        print(result)


if __name__ == "__main__":
    main()
