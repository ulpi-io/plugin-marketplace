# DingTalk webhook config
DINGTALK_PORT=3210
DINGTALK_PATH=/dingtalk
DINGTALK_SIGNING_SECRET=your_signing_secret
DINGTALK_BOT_ID=
DINGTALK_BOT_NAME=

# Clawdbot config
CLAWDBOT_CONFIG_PATH=~/.clawdbot/clawdbot.json
CLAWDBOT_AGENT_ID=main

# Reply delay before sending a "Thinking..." message (ms), set 0 to disable
DINGTALK_THINKING_THRESHOLD_MS=2500
