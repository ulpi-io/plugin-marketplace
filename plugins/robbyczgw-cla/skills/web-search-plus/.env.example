# ============================================================================
# Web Search Plus — API Keys
# ============================================================================
# Copy this file to .env and fill in your keys.
# You only need keys for the providers you want to use.
#
# Quick setup:
#   cp .env.example .env
#   # Edit .env with your keys
#   source .env  # loads exports into current shell
#
# IMPORTANT: Keys must use 'export' prefix for Python to read them!
# ============================================================================

# ----------------------------------------------------------------------------
# SERPER — Google Search API
# ----------------------------------------------------------------------------
# Best for: Products, shopping, local, quick facts, news, images
# 
# Get your key:
#   1. Go to https://serper.dev
#   2. Sign up (email or Google)
#   3. Copy API key from dashboard
#
# Pricing:
#   - Free: 2,500 queries (one-time)
#   - Starter: $50/mo for 50,000 queries
#   - Standard: $75/mo for 100,000 queries
#
# Cost: ~$0.001 per query (paid tier)
# ----------------------------------------------------------------------------
export SERPER_API_KEY=

# ----------------------------------------------------------------------------
# TAVILY — AI Research Search
# ----------------------------------------------------------------------------
# Best for: Research, deep dives, synthesized answers, full page content
#
# Get your key:
#   1. Go to https://tavily.com
#   2. Sign up and verify email
#   3. Go to API Keys section
#   4. Generate and copy key
#
# Pricing:
#   - Free: 1,000 queries/month
#   - Basic: $5/mo for 1,000 queries
#   - Pro: $40/mo for 10,000 queries
#
# Cost: ~$0.004 per query (paid tier)
# ----------------------------------------------------------------------------
export TAVILY_API_KEY=

# ----------------------------------------------------------------------------
# EXA — Neural/Semantic Search
# ----------------------------------------------------------------------------
# Best for: Semantic queries, similar pages, company discovery, papers
#
# Get your key:
#   1. Go to https://exa.ai
#   2. Sign up (email or Google)
#   3. Go to API section in dashboard
#   4. Copy your API key
#
# Pricing:
#   - Free: 1,000 queries/month
#   - Pay-as-you-go: ~$0.001 per query
#
# Cost: ~$0.001 per query
# ----------------------------------------------------------------------------
export EXA_API_KEY=

# ----------------------------------------------------------------------------
# YOU.COM — LLM-Ready Web & News Search
# ----------------------------------------------------------------------------
# Best for: RAG applications, real-time info, combined web+news, AI context
#
# Get your key:
#   1. Go to https://api.you.com
#   2. Sign up and create an account
#   3. Generate an API key from the dashboard
#
# Pricing:
#   - Free: Limited queries for testing
#   - Pay-as-you-go: ~$0.001 per query
#   - Enterprise: Custom pricing
#
# Key features:
#   - LLM-optimized snippets (no parsing needed)
#   - Unified web + news in one call
#   - Live crawl for full page content
#   - Automatic news classification
#
# Cost: ~$0.001 per query
# ----------------------------------------------------------------------------
export YOU_API_KEY=

# ----------------------------------------------------------------------------
# SEARXNG — Privacy-First Self-Hosted Meta-Search
# ----------------------------------------------------------------------------
# Best for: Privacy-preserving search, multi-source aggregation, $0 API cost
#
# Set up your instance:
#   1. See https://docs.searxng.org/admin/installation.html
#   2. Easiest: docker run -d -p 8080:8080 searxng/searxng
#   3. Enable JSON format in settings.yml:
#        search:
#          formats: [html, json]
#   4. Set your instance URL below
#
# Pricing:
#   - FREE (self-hosted) — only hosting cost (~$5/mo VPS)
#   - Unlimited queries
#
# Key features:
#   - No tracking, no profiling (privacy-first)
#   - Aggregates 70+ search engines (Google, Bing, DuckDuckGo, etc.)
#   - Full control over your search infrastructure
#   - $0 API cost
#
# Example URLs:
#   - http://localhost:8080 (local Docker)
#   - https://searx.your-domain.com (self-hosted)
#
# NOTE: Most public SearXNG instances disable JSON API!
#       You must run your own instance.
# ----------------------------------------------------------------------------
export SEARXNG_INSTANCE_URL=

# ============================================================================
# OPTIONAL: Default Provider
# ============================================================================
# Set this to automatically use a provider when --provider is not specified
# (Not yet implemented in search.py, but useful for wrapper scripts)
# ----------------------------------------------------------------------------
# DEFAULT_SEARCH_PROVIDER=serper
