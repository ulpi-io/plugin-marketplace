def safe_float(value, default: float = 0.0) -> float:
    """将可能为dict/None/字符串的值安全转为float"""
    if value is None:
        return default
    if isinstance(value, (int, float)):
        return float(value)
    if isinstance(value, dict):
        for k in ("raw", "fmt", "longFmt", "value"):
            if k in value:
                return safe_float(value.get(k), default)
        return default
    try:
        return float(value)
    except Exception:
        return default


