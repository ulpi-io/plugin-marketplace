def main():
    if len(sys.argv) < 2:
        print("Value Investing Stock Analyzer")
        print("巴菲特 + 段永平 投资理念")
        print("\nUsage: analyze-value <TICKER> [options]")
        print("Options:")
        print("  --save       Save report to file")
        print("  --format md  Output as markdown")
        print("  --format json Output as JSON")
        print("\nExamples:")
        print("  analyze-value AAPL")
        print("  analyze-value AMZN --save")
        print("  analyze-value 1810.HK --format md")
        sys.exit(1)
    
    ticker = sys.argv[1].upper()
    save = '--save' in sys.argv
    # 兼容两种写法: --format md / --format=md
    format_md = ('--format' in sys.argv and 'md' in sys.argv) or '--format=md' in sys.argv or ('-f' in sys.argv and 'md' in sys.argv)
    format_json = ('--format' in sys.argv and 'json' in sys.argv) or '--format=json' in sys.argv or ('-f' in sys.argv and 'json' in sys.argv)
    
    try:
        result = value_investing_analysis(ticker)
        
        if format_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        elif format_md:
            save_value_report(result, f"{ticker}-value-analysis.md")
        else:
            print_value_report(result)
            if save:
                save_value_report(result)
    
    except Exception as e:
        print(f"Error analyzing {ticker}: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
