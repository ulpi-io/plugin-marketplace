def build_quality_assessment(profile: Dict, financial: Dict, moat: Dict, margin_of_safety: float, revenue_growth: float) -> Dict:
    """巴菲特+段永平好公司定性评估：业务/盈利模式/文化/四问四看"""
    industry = profile.get('industry', 'N/A')
    sector = profile.get('sector', 'N/A')
    summary = profile.get('longBusinessSummary', '') or ''

    # 公司业务（尽量简洁）
    business = f"{profile.get('longName', profile.get('shortName', '公司'))} 属于{sector}/{industry}，核心是通过平台与基础设施提供产品与服务。"
    if summary:
        business = summary.split('. ')[0].strip() + '。'

    # 盈利模式
    gm = safe_float(financial.get('grossMargins', 0))
    om = safe_float(financial.get('operatingMargins', 0))
    pm = safe_float(financial.get('profitMargins', 0))
    opcf = safe_float(financial.get('operatingCashflow', 0))
    fcf = safe_float(financial.get('freeCashflow', 0))

    model_parts = []
    if gm:
        model_parts.append(f"毛利率约{gm*100:.1f}%")
    if om:
        model_parts.append(f"经营利润率约{om*100:.1f}%")
    if pm:
        model_parts.append(f"净利率约{pm*100:.1f}%")
    if opcf:
        model_parts.append(f"经营现金流约{opcf/1e9:.2f}B")
    if fcf:
        model_parts.append(f"自由现金流约{fcf/1e9:.2f}B")
    business_model = "；".join(model_parts) if model_parts else "盈利模式数据有限，需结合最新财报补充。"

    # 公司文化（启发式）
    officers = profile.get('companyOfficers', []) or []
    founder_keywords = ('Founder', 'Co-Founder', '创始')
    founder_count = 0
    for o in officers[:8]:
        title = (o.get('title') or '')
        if any(k in title for k in founder_keywords):
            founder_count += 1

    culture = []
    if founder_count >= 2:
        culture.append("创始团队仍深度参与管理，战略连续性较强")
    elif founder_count == 1:
        culture.append("核心创始人仍在管理层，长期导向尚可")
    else:
        culture.append("职业经理人主导，需持续跟踪激励与资本配置")

    if moat.get('average', 0) >= 4:
        culture.append("组织在竞争中执行力较强，具备一定长期主义基础")
    else:
        culture.append("组织护城河仍需验证，文化优势未完全固化")

    # 巴菲特四问
    b1 = "是" if moat.get('average', 0) >= 3.5 else "一般"
    b2 = "是" if moat.get('average', 0) >= 4 else "待验证"
    b3 = "偏是" if founder_count >= 1 else "待验证"
    b4 = "是" if margin_of_safety > 15 else "一般" if margin_of_safety > 0 else "否"

    buffett = {
        "业务可理解": b1,
        "可持续护城河": b2,
        "管理层可信": b3,
        "具备安全边际": b4,
    }

    # 段永平四看
    d1 = "是" if pm > 0 and gm > 0.3 else "一般"
    d2 = "偏是" if moat.get('average', 0) >= 3.5 else "待验证"
    d3 = "是" if margin_of_safety > 10 else "一般" if margin_of_safety > 0 else "否"
    d4 = "是" if (safe_float(financial.get('currentRatio', 1)) > 1 or pm > 0) else "否"

    duan = {
        "好生意": d1,
        "好公司": d2,
        "好价格": d3,
        "拿得住": d4,
    }

    return {
        "business": business,
        "business_model": business_model,
        "culture": "；".join(culture),
        "buffett": buffett,
        "duan": duan,
        "revenue_growth_pct": round(revenue_growth * 100, 1),
    }


def evaluate_buffett_duan_standards(forward_pe: float, roe: float, net_margin: float, moat_avg: float,
                                    margin_of_safety: float, fcf_yield: float, peg_1y: float = None) -> Dict:
    """巴菲特 + 段永平评判标准（量化快评）"""
    checks = {
        "巴菲特-ROE>15%": roe >= 15,
        "巴菲特-护城河(>=4/5)": moat_avg >= 4,
        "巴菲特-安全边际>20%": margin_of_safety > 20,
        "巴菲特-估值不过热(PE<=25)": forward_pe > 0 and forward_pe <= 25,
        "段永平-好生意(净利率>=15%)": net_margin >= 15,
        "段永平-现金流质量(FCFY>=3%)": fcf_yield >= 3,
        "段永平-好价格(PEG<=1.5)": (peg_1y is not None and peg_1y <= 1.5),
    }

    passed = sum(1 for v in checks.values() if v)
    total = len(checks)
    score = round(passed / total * 100, 1) if total else 0

    if score >= 85:
        verdict = "✅ 高匹配（可重点跟踪/分批）"
    elif score >= 70:
        verdict = "⏸️ 中等匹配（等待更好价格）"
    else:
        verdict = "⚠️ 低匹配（谨慎）"

    return {
        "checks": checks,
        "passed": passed,
        "total": total,
        "score": score,
        "verdict": verdict,
    }


def summarize_short_term_options(option_chain, current_price: float) -> Dict:
    """汇总近端到期期权的成交量、持仓和ATM隐含波动率"""
    try:
        if option_chain is None or getattr(option_chain, 'empty', True):
            return {"available": False}

        df = option_chain.reset_index().copy()
        if df.empty or 'expiration' not in df.columns:
            return {"available": False}

        exp_dates = sorted(df['expiration'].dropna().unique())
        if not exp_dates:
            return {"available": False}

        nearest_exp = exp_dates[0]
        near_df = df[df['expiration'] == nearest_exp].copy()
        if near_df.empty:
            return {"available": False}

        near_df['volume'] = near_df['volume'].fillna(0)
        near_df['openInterest'] = near_df['openInterest'].fillna(0)
        near_df['impliedVolatility'] = near_df['impliedVolatility'].fillna(0)

        calls = near_df[near_df['optionType'] == 'calls']
        puts = near_df[near_df['optionType'] == 'puts']

        call_vol = float(calls['volume'].sum()) if not calls.empty else 0.0
        put_vol = float(puts['volume'].sum()) if not puts.empty else 0.0
        call_oi = float(calls['openInterest'].sum()) if not calls.empty else 0.0
        put_oi = float(puts['openInterest'].sum()) if not puts.empty else 0.0

        near_df['moneyness_dist'] = (near_df['strike'] - current_price).abs()
        atm = near_df.nsmallest(5, 'moneyness_dist')
        atm_iv = float(atm['impliedVolatility'].mean()) if not atm.empty else 0.0

        return {
            'available': True,
            'nearest_expiration': str(nearest_exp),
            'call_volume': int(call_vol),
            'put_volume': int(put_vol),
            'put_call_volume_ratio': round((put_vol / call_vol), 2) if call_vol > 0 else None,
            'call_open_interest': int(call_oi),
            'put_open_interest': int(put_oi),
            'put_call_oi_ratio': round((put_oi / call_oi), 2) if call_oi > 0 else None,
            'atm_iv': round(atm_iv, 4),
        }
    except Exception:
        return {"available": False}

def calculate_dcf(fcf_current: float, growth_years: List[float], terminal_growth: float, wacc: float, shares: float) -> Dict:
    """
    三阶段DCF估值模型 (Buffett风格)
    
    阶段1: 高成长 (3-5年)
    阶段2: 中成长 (3-5年)  
    阶段3: 永续增长
    """
    if fcf_current <= 0 or shares <= 0:
        return {"intrinsic_value": 0, "sensitivity": []}
    
    # 计算各阶段现值
    fcf = fcf_current
    pv_total = 0
    year = 0
    
    # 阶段1: 高成长
    for growth in growth_years[:3]:  # 前3年高增长
        year += 1
        fcf *= (1 + growth)
        pv_total += fcf / ((1 + wacc) ** year)
    
    # 阶段2: 中成长
    for growth in growth_years[3:5]:  # 接下来2年中增长
        year += 1
        fcf *= (1 + growth)
        pv_total += fcf / ((1 + wacc) ** year)
    
    # 阶段3: 永续增长
    if year > 0:
        terminal_fcf = fcf * (1 + terminal_growth)
        terminal_value = terminal_fcf / (wacc - terminal_growth)
        pv_terminal = terminal_value / ((1 + wacc) ** year)
        pv_total += pv_terminal
    
    intrinsic_value = pv_total / shares
    
    # 敏感性分析
    sensitivity = []
    for w in [wacc - 0.02, wacc, wacc + 0.02]:
        for g in [terminal_growth - 0.005, terminal_growth, terminal_growth + 0.005]:
            if w > g:
                # 重新计算
                fcf_sens = fcf_current
                pv_sens = 0
                for i, growth in enumerate(growth_years[:3]):
                    fcf_sens *= (1 + growth)
                    pv_sens += fcf_sens / ((1 + w) ** (i + 1))
                for i, growth in enumerate(growth_years[3:5]):
                    fcf_sens *= (1 + growth)
                    pv_sens += fcf_sens / ((1 + w) ** (i + 4))
                terminal = fcf_sens * (1 + g) / (w - g) / ((1 + w) ** 5)
                pv_sens += terminal
                iv = pv_sens / shares
                sensitivity.append({"wacc": round(w*100, 1), "growth": round(g*100, 1), "value": round(iv, 2)})
    
    return {
        "intrinsic_value": round(intrinsic_value, 2),
        "sensitivity": sensitivity
    }


def analyze_moat(roe: float, gross_margin: float, net_margin: float, market_cap: float, 
                 industry: str, revenue_growth: float) -> Dict:
    """
    护城河五维分析 (段永平风格)
    """
    moat_scores = {}
    
    # 1. 网络效应护城河
    if market_cap > 500e9:  # 大型平台
        moat_scores["network"] = 5
    elif market_cap > 100e9:
        moat_scores["network"] = 4
    else:
        moat_scores["network"] = 3
    
    # 2. 品牌护城河 (通过ROE和毛利率判断)
    if roe > 0.25 and gross_margin > 0.4:
        moat_scores["brand"] = 5
    elif roe > 0.2 and gross_margin > 0.35:
        moat_scores["brand"] = 4
    elif roe > 0.15:
        moat_scores["brand"] = 3
    else:
        moat_scores["brand"] = 2
    
    # 3. 技术护城河 (通过增长率和行业判断)
    tech_industries = ['Technology', 'Communication Services', 'Healthcare']
    if industry in tech_industries and revenue_growth > 0.15:
        moat_scores["tech"] = 5
    elif industry in tech_industries:
        moat_scores["tech"] = 4
    else:
        moat_scores["tech"] = 3
    
    # 4. 成本优势护城河 (通过净利率判断)
    if net_margin > 0.2:
        moat_scores["cost"] = 5
    elif net_margin > 0.15:
        moat_scores["cost"] = 4
    elif net_margin > 0.1:
        moat_scores["cost"] = 3
    else:
        moat_scores["cost"] = 2
    
    # 5. 切换成本护城河 (通过ROE稳定性判断)
    if roe > 0.2:
        moat_scores["switching"] = 5
    elif roe > 0.15:
        moat_scores["switching"] = 4
    else:
        moat_scores["switching"] = 3
    
    avg_moat = sum(moat_scores.values()) / len(moat_scores)
    
    return {
        "scores": moat_scores,
        "average": round(avg_moat, 1),
        "rating": "极宽" if avg_moat >= 4.5 else "宽阔" if avg_moat >= 4 else "中等" if avg_moat >= 3 else "狭窄"
    }


def calculate_future_value(current_price: float, intrinsic_value: float, 
                          growth_rate: float, years: int) -> Dict:
    """
    计算未来1-5年的价值估算
    """
    results = {}
    
    for year in range(1, years + 1):
        # 基于增长率和内在价值的复合增长
        future_value = intrinsic_value * ((1 + growth_rate) ** year)
        
        # 年化回报率
        if current_price > 0:
            annual_return = ((future_value / current_price) ** (1/year) - 1) * 100
        else:
            annual_return = 0
        
        results[year] = {
            "value": round(future_value, 2),
            "annual_return": round(annual_return, 1)
        }
    
    return results


def value_investing_analysis(ticker: str) -> Dict:
    """
    价值投资分析 (巴菲特 + 段永平 风格)
    """
    try:
        from yahooquery import Ticker
    except ImportError:
        print("Error: yahooquery not installed. Run: pip install yahooquery")
        sys.exit(1)
    
    print(f"🔍 正在进行价值投资分析: {ticker}...")
    print("💡 理念: 买公司，不是买股票 | 和时间做朋友 | 左侧交易\n")
    
    stock = Ticker(ticker)
    
    # 基础数据
    price_data = stock.price.get(ticker, {})
    stats_data = stock.key_stats.get(ticker, {})
    financial = stock.financial_data.get(ticker, {})
    profile = stock.asset_profile.get(ticker, {})
    cashflow = stock.cash_flow(frequency='a')
    income = stock.income_statement(frequency='a')
    earnings_trend = stock.earnings_trend
    option_chain = stock.option_chain
    
    current_price = safe_float(price_data.get('regularMarketPrice', 0))
    market_cap = safe_float(price_data.get('marketCap', 0))
    shares = safe_float(stats_data.get('sharesOutstanding', 0))
    
    high_52w = safe_float(price_data.get('fiftyTwoWeekHigh', current_price * 1.2), current_price * 1.2)
    low_52w = safe_float(price_data.get('fiftyTwoWeekLow', current_price * 0.8), current_price * 0.8)

    # 短期期权成交量与隐含波动率
    options_summary = summarize_short_term_options(option_chain, current_price)
    
    # 财务指标
    roe = safe_float(financial.get('returnOnEquity', 0))
    roa = safe_float(financial.get('returnOnAssets', 0))
    gross_margin = safe_float(financial.get('grossMargins', 0))
    operating_margin = safe_float(financial.get('operatingMargins', 0))
    net_margin = safe_float(financial.get('profitMargins', 0))
    
    forward_pe = safe_float(stats_data.get('forwardPE', 0))
    pb = safe_float(stats_data.get('priceToBook', 0))
    
    # 获取FCF (尝试多种方式)
    fcf = 0
    ocf = 0
    capex = 0
    
    if cashflow is not None and not cashflow.empty:
        # 尝试获取FCF
        for col in cashflow.columns:
            if 'FreeCashFlow' in cashflow.index:
                fcf_val = cashflow.loc['FreeCashFlow', col]
                if fcf_val and fcf_val == fcf_val and fcf_val != 0:
                    fcf = fcf_val
                    break
        
        # 如果没有FCF，用OCF - Capex计算
        if fcf == 0:
            for col in cashflow.columns:
                if 'OperatingCashFlow' in cashflow.index:
                    ocf_val = cashflow.loc['OperatingCashFlow', col]
                    if ocf_val and ocf_val == ocf_val:
                        ocf = ocf_val
                        break
                if 'CapitalExpenditure' in cashflow.index:
                    capex_val = cashflow.loc['CapitalExpenditure', col]
                    if capex_val and capex_val == capex_val:
                        capex = abs(capex_val)  # Capex通常是负数
                        break
            
            if ocf > 0:
                fcf = ocf - capex
    
    # financial_data 兜底（很多标的在cash_flow表中字段不稳定）
    if fcf == 0:
        fcf = safe_float(financial.get('freeCashflow', 0), 0)
    if ocf == 0:
        ocf = safe_float(financial.get('operatingCashflow', 0), 0)

    # 如果还是获取不到，用净利润估算
    if fcf == 0 and net_margin and income is not None and not income.empty:
        for col in income.columns:
            if 'NetIncome' in income.index:
                net_income = income.loc['NetIncome', col]
                if net_income and net_income == net_income and net_income > 0:
                    # FCF ≈ 净利润 + 折旧 - 资本支出 (简化)
                    fcf = net_income * 0.7  # 保守估计
                    break
    
    fcf_per_share = fcf / shares if shares else 0
    ocf_per_share = ocf / shares if shares and ocf else 0
    
    # 增长预期
    eps_growth_1y = 0
    eps_growth_2y = 0
    revenue_growth = 0
    
    if earnings_trend:
        trend_data = earnings_trend.get(ticker, {}).get('trend', [])
        for item in trend_data:
            period = item.get('period')
            if period == '0y':
                eps_growth_1y = safe_float(item.get('growth', 0), 0)
                revenue_growth = safe_float(item.get('revenueEstimate', {}).get('growth', 0), 0)
            elif period == '+1y':
                eps_growth_2y = safe_float(item.get('growth', 0), 0)
    
    if revenue_growth == 0:
        revenue_growth = safe_float(financial.get('revenueGrowth', 0), 0)

    # 护城河分析
    moat = analyze_moat(roe, gross_margin, net_margin, market_cap, 
                        profile.get('sector', ''), revenue_growth)
    
    # DCF估值 (三阶段) - 使用保守的FCF估计
    fcf_for_dcf = fcf if fcf > 0 else market_cap * 0.03  # 如果获取不到，用市值的3%估算
    
    growth_years = [eps_growth_1y if eps_growth_1y > 0 else 0.1,
                    eps_growth_1y if eps_growth_1y > 0 else 0.1,
                    eps_growth_2y if eps_growth_2y > 0 else 0.08,
                    0.08, 0.05]  # 5年增长假设
    
    dcf_result = calculate_dcf(fcf_for_dcf, growth_years, 0.025, 0.09, shares)
    intrinsic_value = dcf_result["intrinsic_value"]
    
    # 如果DCF计算失败，使用简化估值
    if intrinsic_value <= 0:
        # 简化估值：P/E法
        if forward_pe > 0 and eps_growth_1y > 0:
            # 合理P/E = 增长率 * 100
            fair_pe = eps_growth_1y * 100 * 1.5  # 给予50%溢价
            eps_estimate = current_price / forward_pe * (1 + eps_growth_1y)
            intrinsic_value = eps_estimate * fair_pe
        else:
            intrinsic_value = current_price * 1.2  # 保守估计
    
    # 安全边际
    margin_of_safety = ((intrinsic_value - current_price) / intrinsic_value * 100) if intrinsic_value > 0 else 0
    
    # 未来价值估算
    avg_growth = (eps_growth_1y + eps_growth_2y) / 2 if eps_growth_1y and eps_growth_2y else 0.1
    iv_for_future = intrinsic_value if intrinsic_value > 0 else current_price * 1.2
    future_values = calculate_future_value(current_price, iv_for_future, avg_growth, 5)
    
    # 左侧交易价格区间（修正区间上下界，确保 min <= max）
    first_batch_min = current_price * 0.95
    first_batch_max = current_price * 1.05

    second_batch_min = current_price * 0.85
    second_batch_max = current_price * 0.95

    heavy_min = max(low_52w * 0.95, current_price * 0.75)
    heavy_max = second_batch_min
    if heavy_min > heavy_max:
        heavy_min, heavy_max = heavy_max * 0.9, heavy_max

    extreme = heavy_min
    
    # 巴菲特 + 段永平定性评估
    quality = build_quality_assessment(profile, financial, moat, margin_of_safety, revenue_growth)

    # PEG（用于结构化输出）
    peg_1y = (forward_pe / (eps_growth_1y * 100)) if forward_pe > 0 and eps_growth_1y > 0 else None
    peg_2y = (forward_pe / (eps_growth_2y * 100)) if forward_pe > 0 and eps_growth_2y > 0 else None

    # 巴菲特 + 段永平评判标准（量化）
    fcf_yield_pct = (fcf_per_share / current_price * 100) if current_price else 0
    standards = evaluate_buffett_duan_standards(
        forward_pe=forward_pe,
        roe=roe * 100 if roe else 0,
        net_margin=net_margin * 100 if net_margin else 0,
        moat_avg=moat.get('average', 0),
        margin_of_safety=margin_of_safety,
        fcf_yield=fcf_yield_pct,
        peg_1y=peg_1y,
    )

    # 市场时钟（中期选举/节假日/月份季节性）
    calendar = build_calendar_context(datetime.now(), profile.get('sector', ''))

    # 期权现金流策略（用户偏好：虚值long call + 50%-100%减仓回流）
    options_strategy = build_otm_long_call_plan(current_price, option_chain)

    # 五维评分
    score_valuation = 5 if margin_of_safety > 30 else 4 if margin_of_safety > 15 else 3 if margin_of_safety > 0 else 2
    score_moat = int(moat["average"])
    score_fcf = 5 if fcf > 0 and fcf/market_cap > 0.03 else 4 if fcf > 0 else 3
    score_profit = 5 if roe > 0.2 else 4 if roe > 0.15 else 3 if roe > 0.1 else 2
    score_growth = 5 if avg_growth > 0.2 else 4 if avg_growth > 0.15 else 3 if avg_growth > 0.1 else 2
    
    total_score = (score_valuation + score_moat + score_fcf + score_profit + score_growth) / 5
    
    # 投资评级
    if total_score >= 4.5 and margin_of_safety > 20:
        rating = "STRONG BUY ⭐⭐⭐⭐⭐"
    elif total_score >= 4 and margin_of_safety > 10:
        rating = "BUY ⭐⭐⭐⭐"
    elif total_score >= 3.5:
        rating = "HOLD ⭐⭐⭐"
    else:
        rating = "AVOID ⭐⭐"
    
    return {
        "framework": "Buffett+Duan qualitative + Five-Dimension Value Framework v2",
        "ticker": ticker,
        "name": profile.get('shortName', ticker),
        "date": datetime.now().strftime("%Y-%m-%d"),
        
        "price": {
            "current": round(current_price, 2),
            "market_cap_b": round(market_cap / 1e9, 2),
            "week_52_high": round(high_52w, 2),
            "week_52_low": round(low_52w, 2),
            "position_pct": round((current_price - low_52w) / (high_52w - low_52w) * 100, 1) if high_52w != low_52w else 0,
            "drop_from_high": round((high_52w - current_price) / high_52w * 100, 1) if high_52w else 0,
        },
        
        "valuation": {
            "forward_pe": round(forward_pe, 1),
            "pb": round(pb, 2),
            "intrinsic_value": intrinsic_value,
            "margin_of_safety": round(margin_of_safety, 1),
        },
        
        "fundamentals": {
            "roe": round(roe * 100, 1) if roe else None,
            "roa": round(roa * 100, 1) if roa else None,
            "gross_margin": round(gross_margin * 100, 1) if gross_margin else None,
            "net_margin": round(net_margin * 100, 1) if net_margin else None,
        },
        
        "cashflow": {
            "ocf_b": round(ocf / 1e9, 2) if ocf else None,
            "ocf_per_share": round(ocf_per_share, 2) if ocf_per_share else 0,
            "fcf_b": round(fcf / 1e9, 2) if fcf else None,
            "fcf_per_share": round(fcf_per_share, 2),
            "fcf_yield": round(fcf_per_share / current_price * 100, 2) if current_price else 0,
        },
        
        "growth": {
            "eps_growth_1y": round(eps_growth_1y * 100, 1),
            "eps_growth_2y": round(eps_growth_2y * 100, 1),
            "revenue_growth": round(revenue_growth * 100, 1),
        },

        "quality": quality,
        "standards": standards,
        "calendar": calendar,

        "options": options_summary,
        "options_strategy": options_strategy,
        
        "moat": moat,
        
        "peg": {
            "peg_1y": round(peg_1y, 2) if peg_1y is not None else None,
            "peg_2y": round(peg_2y, 2) if peg_2y is not None else None,
        },

        "dcf": {
            **dcf_result,
            "assumptions": {
                "base_fcf_b": round(fcf_for_dcf / 1e9, 2) if fcf_for_dcf else None,
                "stage1_growth_pct": round((growth_years[0] if growth_years else 0) * 100, 1),
                "stage2_growth_pct": round((growth_years[2] if len(growth_years) > 2 else 0) * 100, 1),
                "terminal_growth_pct": 2.5,
                "wacc_pct": 9.0,
            }
        },
        
        "future_value": future_values,
        
        "entry_points": {
            "first_batch": (round(first_batch_min, 2), round(first_batch_max, 2)),
            "second_batch": (round(second_batch_min, 2), round(second_batch_max, 2)),
            "heavy": (round(heavy_min, 2), round(heavy_max, 2)),
            "extreme": round(extreme, 2),
        },
        
        "scores": {
            "valuation": score_valuation,
            "moat": score_moat,
            "fcf": score_fcf,
            "profitability": score_profit,
            "growth": score_growth,
            "total": round(total_score, 1),
        },
        
        "rating": rating,
        "sector": profile.get('sector', 'N/A'),
        "industry": profile.get('industry', 'N/A'),
        "ceo": profile.get('companyOfficers', [{}])[0].get('name', 'N/A') if profile.get('companyOfficers') else 'N/A',
    }


