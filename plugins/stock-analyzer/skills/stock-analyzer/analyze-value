def save_value_report(data: Dict, filename: str = None):
    """保存价值投资报告为Markdown"""
    if not filename:
        filename = f"./{data['ticker']}-value-analysis-{data['date']}.md"
    
    with open(filename, 'w', encoding='utf-8') as f:
        f.write(f"# {data['name']} ({data['ticker']}) 价值投资分析报告\n\n")
        f.write(f"> 💡 投资理念: 买公司，不是买股票 | 和时间做朋友 | 左侧交易\n\n")
        f.write(f"**分析日期**: {data['date']}\n\n")
        
        f.write("## 🧭 巴菲特 + 段永平好公司评估\n\n")
        q = data.get('quality', {})
        if q:
            f.write(f"- **公司业务**: {q.get('business', 'N/A')}\n")
            f.write(f"- **盈利模式**: {q.get('business_model', 'N/A')}\n")
            f.write(f"- **公司文化**: {q.get('culture', 'N/A')}\n")
            b = q.get('buffett', {})
            d = q.get('duan', {})
            f.write(f"- **巴菲特四问**: 业务可理解={b.get('业务可理解','N/A')} / 护城河={b.get('可持续护城河','N/A')} / 管理层={b.get('管理层可信','N/A')} / 安全边际={b.get('具备安全边际','N/A')}\n")
            f.write(f"- **段永平四看**: 好生意={d.get('好生意','N/A')} / 好公司={d.get('好公司','N/A')} / 好价格={d.get('好价格','N/A')} / 拿得住={d.get('拿得住','N/A')}\n")
        f.write("\n")

        if data.get('standards'):
            s = data['standards']
            f.write("## 🧪 巴菲特 + 段永平投资评判标准\n\n")
            for k, v in s.get('checks', {}).items():
                f.write(f"- **{k}**: {'✅ 达标' if v else '❌ 未达标'}\n")
            f.write(f"- **总分**: {s.get('passed', 0)}/{s.get('total', 0)} ({s.get('score', 0)}分)\n")
            f.write(f"- **结论**: {s.get('verdict', 'N/A')}\n\n")

        f.write("## 📊 核心数据\n\n")
        f.write(f"- **股价**: ${data['price']['current']}\n")
        f.write(f"- **市值**: ${data['price']['market_cap_b']:.1f}B\n")
        f.write(f"- **52周区间**: ${data['price']['week_52_low']} - ${data['price']['week_52_high']}\n")
        f.write(f"- **Forward P/E**: {data['valuation']['forward_pe']}x\n")
        if data.get('options', {}).get('available'):
            f.write(f"- **短期期权P/C成交量比**: {data['options'].get('put_call_volume_ratio')}\n")
            f.write(f"- **短期期权ATM IV**: {round(data['options'].get('atm_iv', 0) * 100, 2)}%\n")
        f.write("\n")

        os = data.get('options_strategy', {})
        if os.get('available'):
            f.write("## 🧠 期权现金流策略（虚值 Long Call）\n\n")
            f.write(f"- **策略**: {os.get('strategy')}\n")
